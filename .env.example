# ─── Servidor ─────────────────────────────────────────────
PORT=3000
NODE_ENV=development          # development | production

# ─── Supabase ─────────────────────────────────────────────
SUPABASE_URL=https://TU_PROJECT_ID.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGci...  # Settings → API → service_role key

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=cambia_este_secreto_por_uno_largo_y_aleatorio

# ─── Stripe ───────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...      # sk_test_... en desarrollo
STRIPE_WEBHOOK_SECRET=whsec_...    # Stripe Dashboard → Webhooks

# ─── PayU Latam ───────────────────────────────────────────
PAYU_MERCHANT_ID=TU_MERCHANT_ID
PAYU_API_KEY=TU_API_KEY
PAYU_API_LOGIN=TU_API_LOGIN
PAYU_ACCOUNT_ID=TU_ACCOUNT_ID
PAYU_SANDBOX=true                  # false en producción

# ─── Email (Gmail SMTP) ───────────────────────────────────
# Usa una Contraseña de Aplicación de Google (myaccount.google.com → Seguridad → Contraseñas de aplicaciones)
# Requiere 2FA activado en la cuenta Gmail. NO uses la contraseña normal de Gmail.
EMAIL_USER=tucorreo@gmail.com
EMAIL_PASS=abcd efgh ijkl mnop   # App Password de 16 caracteres (sin espacios al configurar)

# ─── Expo Push Notifications ──────────────────────────────
EXPO_ACCESS_TOKEN=TU_EXPO_TOKEN    # expo.dev → Account → Access Tokens

# ─── URLs ─────────────────────────────────────────────────
API_BASE_URL=https://api.bocarafood.com   # URL pública del backend

# ─── Delivery (tarifas base en GTQ) ───────────────────────
DELIVERY_BASE_FEE_GTM_CITY=15
DELIVERY_BASE_FEE_METRO=25
DELIVERY_BASE_FEE_INTERIOR=50

# ─── Guatex (opcional) ────────────────────────────────────
GUATEX_API_URL=https://api.guatex.com.gt/v1
GUATEX_API_KEY=TU_KEY

# ─── Forza Delivery (opcional) ────────────────────────────
FORZA_API_URL=https://api.forzadelivery.com/v2
FORZA_API_KEY=TU_KEY

# ─── EasyPost (opcional) ──────────────────────────────────
EASYPOST_API_KEY=TU_KEY

# ─── Cubo Pago Guatemala — https://developers.cubopago.com ───────────────────
# Producción (configurar en Render Dashboard — nunca hardcodear en código)
CUBO_API_URL=https://api-payment-a.cubopago.com
CUBO_API_KEY=TU_API_KEY_PRODUCCION          # Cubo Admin → Developers → API Keys
CUBO_ENVIRONMENT=production                 # "production" activa validación al iniciar
CUBO_PAYMENTS_ENABLED=false                 # cambiar a true solo tras verificar config completa

# Desarrollo local / sandbox
# CUBO_API_URL=https://api-payment-sandbox.cubopago.com
# CUBOPAGO_API_KEY=TU_API_KEY_SANDBOX       # fallback dev (no usar en producción)
# CUBO_ENVIRONMENT=sandbox
